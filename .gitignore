# =====================================================
# .gitignore for Inferno Jockey
# Unity 6 · Windows · Visual Studio · Asset Store
# =====================================================


# ── Unity generated folders ──────────────────────────
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Unity 6 specific cache
[Gg]lobal[Cc]ache/


# ── Unity asset meta files ────────────────────────────
# Keep .meta files — Unity needs them to track GUIDs.
# Do NOT add *.meta here.


# ── Asset Store packages ─────────────────────────────
# Downloaded .unitypackage files don't belong in source
# control — they can always be re-downloaded from your
# account. Add them to a local /Packages-local/ folder
# outside the project if you want to keep them handy.
Assets/AssetStorePackages/
*.unitypackage


# ── Visual Studio ─────────────────────────────────────
.vs/
*.csproj
*.sln
*.suo
*.user
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# VS code analysis
.vscode/


# ── C# build artefacts ────────────────────────────────
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
*.pidb.meta
*.pdb.meta
*.mdb.meta


# ── WebGL build output ────────────────────────────────
# Builds are reproducible from source; don't commit them.
[Bb]uild/
[Bb]uilds/
WebGL/


# ── OS / Windows noise ────────────────────────────────
Thumbs.db
Thumbs.db:encdata
Desktop.ini
$RECYCLE.BIN/
*.lnk


# ── JetBrains Rider (optional — included in case you ──
# ── ever switch from Visual Studio) ──────────────────
.idea/
*.sln.iml


# ── Node / npm (if you use docx-js or other tooling) ──
node_modules/
package-lock.json


# ── Crash & editor logs ───────────────────────────────
sysinfo.txt
*.stackdump
MemoryCaptures/
[Aa]ssets/[Ss]treamingAssets/aa.meta
[Aa]ssets/[Ss]treamingAssets/aa/


# ── Unity Burst compiler cache ────────────────────────
BurstCache/


# ── Unity Addressables (if used later) ───────────────
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/
FastCached/


# ── PIX captures & profiler snapshots ────────────────
*.trace
*.raw


# ── Personal / sensitive ──────────────────────────────
# Uncomment if you store any secrets locally:
# secrets.json
# .env
